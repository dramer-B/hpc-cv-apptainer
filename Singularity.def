Bootstrap: docker
From: python:3.12-slim

%post
    # Set environment variables
    export DEBIAN_FRONTEND=noninteractive
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1

    # 1. Install System Dependencies
    apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    wget \
    unzip \
    pkg-config \
    libx11-dev \
    libopenblas-dev \
    libgtk-3-dev \
    libboost-python-dev \
    && rm -rf /var/lib/apt/lists/*

    # 2. Python Setup
    pip install --upgrade pip

    # 3. Install Heavy Libraries (Dlib + OpenCV)
    pip install dlib
    pip install opencv-python-headless numpy

%test
    # Verification script
    python3 -c "import dlib; import cv2; print('VERIFICATION SUCCESS -> Dlib:', dlib.__version__, '| OpenCV:', cv2.__version__)"

%labels
    Author Aarav
    Version 1.0.0

    Description Python 3.12 + Dlib + OpenCV for Red Hen Lab
